{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":configMigration",
        ":semanticCommitTypeAll(chore)",
        "group:allNonMajor",
        "group:allDigest"
    ],
    "timezone": "Asia/Tokyo",
    "platformAutomerge": false,
    "rebaseWhen": "auto",
    "schedule": [
        "after 1am and before 3am on monday"
    ],
    "prHourlyLimit": 0,
    "updateNotScheduled": false,
    "dependencyDashboard": true,
    "internalChecksFilter": "none",
    "packageRules": [
        {
            "matchPackageNames": [
                "*"
            ],
            "rangeStrategy": "replace"
        },
        {
            "matchUpdateTypes": [
                "major"
            ],
            "minimumReleaseAge": "5 days",
            "dependencyDashboardApproval": true,
            "addLabels": [
                "renovate/major"
            ]
        },
        {
            "matchUpdateTypes": [
                "minor"
            ],
            "minimumReleaseAge": "14 days",
            "addLabels": [
                "renovate/minor"
            ],
            "automerge": true
        },
        {
            "matchUpdateTypes": [
                "patch"
            ],
            "minimumReleaseAge": "14 days",
            "addLabels": [
                "renovate/patch"
            ],
            "automerge": true
        },
        {
            "matchUpdateTypes": [
                "pin"
            ],
            "addLabels": [
                "renovate/pin"
            ],
            "automerge": true
        },
        {
            "matchUpdateTypes": [
                "digest"
            ],
            "automerge": true
        },
        {
            "matchDepTypes": [
                "action"
            ],
            "matchPackageNames": [
                "!actions/{/,}**"
            ],
            "pinDigests": true
        },
        {
            "description": "pnpm 11.12.0 is a broken release: its tarball fails to install, so any self-switch to it crashes (pnpm/pnpm#12955, pnpm/action-setup#276). Remove once a fixed release ships.",
            "matchPackageNames": [
                "pnpm"
            ],
            "allowedVersions": "!/^11\\.12\\.0$/"
        }
    ]
}
